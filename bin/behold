#!/usr/bin/env ruby
# frozen_string_literal: true

require 'behold'
require 'literal_parser'

abort 'usage: behold FROM TO' if ARGV.size < 2

begin
  from = LiteralParser.parse ARGV.shift
  to = LiteralParser.parse ARGV.shift
rescue SyntaxError => e
  abort "behold: #{e.message}"
end

puts Behold.code(from, to)
