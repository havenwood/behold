#!/usr/bin/env ruby
# frozen_string_literal: true

require 'behold'
require 'behold/literal'

abort 'usage: behold FROM TO' if ARGV.size < 2

begin
  from = Behold::Literal.parse ARGV.shift
  to = Behold::Literal.parse ARGV.shift
rescue ArgumentError => e
  abort "behold: #{e.message}"
end

puts Behold.code(from, to)
